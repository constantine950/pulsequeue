
# ── Application ──────────────────────────────────
APP_NAME=PulseQueue
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# ── PostgreSQL ───────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulsequeue
DB_MIN_CONNECTIONS=2
DB_MAX_CONNECTIONS=10

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_BRPOP_TIMEOUT=5

# ── Worker ───────────────────────────────────────
WORKER_HEARTBEAT_INTERVAL=10
WORKER_STALE_THRESHOLD=30
WORKER_DEFAULT_CONCURRENCY=1

# ── Retry ────────────────────────────────────────
RETRY_BASE_DELAY=4
RETRY_MAX_DELAY=3600
RETRY_JITTER=true

# ── Scheduler ────────────────────────────────────
SCHEDULER_POLL_INTERVAL=1.0

# ── Jobs ─────────────────────────────────────────
JOB_DEFAULT_TIMEOUT=300
JOB_DEFAULT_MAX_RETRIES=3
